[
  {
    "kernelSource": {
      "name": "Redmi2",
      "repo": "https://github.com/Ark-uki/android-kernel-msm8916",
      "branch": "wip/6.12",
      "device": "wt88047",
      "defconfig": "msm8916_defconfig"
    },
    "toolchains": [
      {
        "repo": "https://android.googlesource.com/platform/prebuilts/clang/host/linux-x86/",
        "branch": "main-kernel-2025",
        "name": "clang",
        "binaryEnv": [
          "bin"
        ]
      },
      {
        "repo": "https://android.googlesource.com/platform/prebuilts/gcc/linux-x86/host/x86_64-linux-glibc2.17-4.8/",
        "branch": "main-kernel-2025",
        "name": "aarch64",
        "binaryEnv": [
          "bin"
        ]
      },
      {
        "repo": "https://android.googlesource.com/platform/prebuilts/gcc/linux-x86/host/x86_64-linux-glibc2.17-4.8/",
        "branch": "main-kernel-2025",
        "name": "arm",
        "binaryEnv": [
          "bin"
        ]
      }
    ],
    "enableCcache": true,
    "params": {
      "ARCH": "arm64",
      "CC": "clang",
      "externalCommands": {
        "CLANG_TRIPLE": "aarch64-linux-gnu-",
        "CROSS_COMPILE": "aarch64-linux-android-",
        "CROSS_COMPILE_ARM32": "arm-linux-androideabi-",
        "LD": "ld.lld",
        "AR": "llvm-ar",
        "NM": "llvm-nm",
        "OBJCOPY": "llvm-objcopy",
        "OBJDUMP": "llvm-objdump",
        "READELF": "llvm-readelf",
        "OBJSIZE": "llvm-size",
        "STRIP": "llvm-strip",
        "LDGOLD": "aarch64-linux-gnu-ld.gold",
        "LLVM_AR": "llvm-ar",
        "LLVM_DIS": "llvm-dis",
        "CONFIG_THINLTO": ""
      }
    },
    "AnyKernel3": {
      "use": true,
      "release": true
    },
    "enableKernelSU": true,
    "enableLXC": true
  }
]
